# =============================================================================
# Configuración CRON para PubMed España
# =============================================================================
#
# Copiar este archivo a /etc/cron.d/pubmed-update o añadir las líneas
# relevantes a tu crontab personal (crontab -e).
#
# Requisitos:
#   - Variable de entorno PUBMED_DB_PASSWORD debe estar definida
#   - El entorno virtual debe estar en /home/marc/db-projects/pubmed/venv
#   - El usuario debe tener permisos de escritura en data/logs/
#
# =============================================================================

# Variables de entorno necesarias (si usas cron del sistema)
PUBMED_DB_PASSWORD=tu_password_aqui
PATH=/usr/local/bin:/usr/bin:/bin

# =============================================================================
# ACTUALIZACIÓN DIARIA
# =============================================================================

# Descarga incremental + actualización de especialidades
# Ejecuta a las 3:00 AM (hora off-peak de NCBI para España)
# Mejor hora: 9pm-5am EST = 3am-11am hora española
0 3 * * * cd /home/marc/db-projects/pubmed && ./venv/bin/python scripts/cron_update.py >> data/logs/cron.log 2>&1

# =============================================================================
# ESTADÍSTICAS SEMANALES (opcional)
# =============================================================================

# Genera estadísticas detalladas cada domingo a las 6:00 AM
0 6 * * 0 cd /home/marc/db-projects/pubmed && ./venv/bin/python scripts/statistics.py >> data/logs/stats.log 2>&1

# =============================================================================
# MANTENIMIENTO MENSUAL (opcional)
# =============================================================================

# Actualizar términos MeSH (se publican anualmente, pero por si acaso)
# Primer día de cada mes a las 4:00 AM
# 0 4 1 * * cd /home/marc/db-projects/pubmed && ./venv/bin/python scripts/import_mesh_terms.py >> data/logs/mesh.log 2>&1

# =============================================================================
# NOTAS
# =============================================================================
#
# Rate limits de NCBI:
#   - Sin API Key: 3 requests/segundo
#   - Con API Key: 10 requests/segundo
#   - Horas off-peak (más flexibles): 9pm-5am EST (fin de semana todo el día)
#
# Para obtener una API Key gratuita:
#   https://www.ncbi.nlm.nih.gov/account/settings/
#
# Monitoreo de logs:
#   tail -f data/logs/cron.log
#
# Verificar última ejecución:
#   head -20 data/logs/cron.log | tail -15
#
# =============================================================================
