# Environment variables for the PubMed downloader.
# Copy this file to .env and fill in your own values.

# PostgreSQL database.
PUBMED_DB_HOST=localhost
PUBMED_DB_PORT=5432
PUBMED_DB_NAME=pubmed_db
PUBMED_DB_USER=pubmed_user
PUBMED_DB_PASSWORD=your_password_here

# PubMed API key (optional, raises the rate limit from 3 to 10 req/s).
# Get one for free at: https://www.ncbi.nlm.nih.gov/account/settings/
# PUBMED_API_KEY=your_api_key_here
