# Variables de entorno para PubMed Downloader
# Copia este archivo a .env y configura tus valores

# Base de datos PostgreSQL
PUBMED_DB_HOST=localhost
PUBMED_DB_PORT=5432
PUBMED_DB_NAME=pubmed_db
PUBMED_DB_USER=pubmed_user
PUBMED_DB_PASSWORD=tu_password_aqui

# PubMed API (opcional, aumenta rate limit de 3 a 10 req/s)
# Obtén tu API key gratis en: https://www.ncbi.nlm.nih.gov/account/settings/
# PUBMED_API_KEY=tu_api_key_aqui
